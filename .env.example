# String de conexão do Postgres (usada pelo Prisma)
DATABASE_URL="postgresql://mqtt:mqtt@localhost:5432/mqtt_poc"
# Porta HTTP em que a API escuta
PORT=3333
# Ambiente de execução (development | production) — afeta logs e otimizações
NODE_ENV=development
# Origem do frontend liberada no CORS (vale para REST e WebSocket)
WEB_ORIGIN="http://localhost:5173"
# Endereço do broker MQTT — use mqtts:// para TLS (ex.: broker gerenciado na porta 8883)
MQTT_URL="mqtt://localhost:1883"
# Usuário de autenticação no broker (vazio = conexão anônima)
MQTT_USERNAME=
# Senha de autenticação no broker
MQTT_PASSWORD=
# Qualidade de entrega das mensagens MQTT: 0 (no máximo 1x), 1 (ao menos 1x) ou 2 (exatamente 1x)
MQTT_QOS=1
# Tempo (ms) que o cadastro espera pela leitura do status RETIDO do device no broker
# (reconcilia o status quando o device já estava online antes de ser cadastrado)
MQTT_RETAINED_READ_TIMEOUT_MS=800
# Tempo (ms) até um comando sem resposta do device ser marcado como TIMEOUT
MQTT_COMMAND_TIMEOUT_MS=60000
# De quanto em quanto tempo (ms) a API varre comandos pendentes vencidos
MQTT_COMMAND_EXPIRY_CHECK_INTERVAL_MS=10000
# Sem heartbeat por mais que isso (ms), um device ONLINE é marcado OFFLINE (~3x o heartbeat do device)
DEVICE_OFFLINE_TIMEOUT_MS=45000
# De quanto em quanto tempo (ms) a API checa devices inativos para marcá-los OFFLINE
DEVICE_LIVENESS_CHECK_INTERVAL_MS=10000
