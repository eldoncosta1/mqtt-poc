# Endereço do broker MQTT — use mqtts:// para TLS (ex.: broker gerenciado na porta 8883)
MQTT_URL="mqtt://localhost:1883"
# Usuário de autenticação no broker (vazio = conexão anônima)
MQTT_USERNAME=
# Senha de autenticação no broker
MQTT_PASSWORD=
# Qualidade de entrega das mensagens MQTT: 0, 1 ou 2
MQTT_QOS=1
# Identificador do dispositivo — precisa casar com o externalId cadastrado na API (obrigatório)
DEVICE_EXTERNAL_ID="device-001"
# Atraso simulado (ms) antes de o device responder a um comando
SIMULATOR_RESPONSE_DELAY_MS=1000
# Probabilidade (0 a 1) de responder FAILED em vez de ACKED — simula falhas do device
SIMULATOR_FAILURE_RATE=0
# Intervalo (ms) em que o device republica "online" para manter o status vivo (0 desliga o heartbeat)
SIMULATOR_HEARTBEAT_MS=15000
# Liga/desliga a publicação de telemetria GPS (false desliga)
SIMULATOR_GPS_ENABLED=true
# Intervalo (ms) entre publicações de posição GPS (0 desliga o GPS)
SIMULATOR_GPS_INTERVAL_MS=3000
# Coordenada inicial do passeio aleatório (latitude)
SIMULATOR_GPS_START_LAT=-9.3986
# Coordenada inicial do passeio aleatório (longitude)
SIMULATOR_GPS_START_LON=-40.5008
# Tamanho máximo (graus) de cada passo do passeio aleatório
SIMULATOR_GPS_STEP_DEG=0.0005
