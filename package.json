{
  "name": "mqtt-poc",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "postinstall": "pnpm --filter @mqtt-poc/shared build",
    "dev:api": "pnpm --filter @mqtt-poc/api dev",
    "dev:web": "pnpm --filter @mqtt-poc/web dev",
    "dev:simulator": "pnpm --filter @mqtt-poc/device-simulator dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @mqtt-poc/shared build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@vitest/coverage-v8": "^2.1.8",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
